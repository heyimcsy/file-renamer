# 환경변수 / 비밀값
.env
.env.*
!.env.example
secrets.*
*.secret
credentials.json
.netrc

# 개인키 / 인증서 / 키스토어
*.pem
*.key
*.p12
*.pfx
*.p8
*.cer
*.crt
*.der
*.jks
*.keystore
id_rsa
id_dsa
id_ecdsa
id_ed25519
*.ppk

# Apple 코드 서명 / 공증(notarization)
*.mobileprovision
*.provisionprofile
*.certSigningRequest

# Tauri 업데이터 / 서명 개인키
.tauri/
*.tauri-key
tauri-private.key
TAURI_SIGNING_PRIVATE_KEY*

# 로컬 설정(사용자별)
.claude/settings.local.json

# =====================================================================
#  빌드 산출물 / 의존성 (용량 큼, 재생성 가능)
